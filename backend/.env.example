# Agricultural Disease Scan – Environment Variables
# =====================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:admin123@localhost:5432/agridisease

# Optional: set to "True" to enable SQLAlchemy SQL query logging
SQL_ECHO=False
